background-opacity = 0.88
background-blur = 3

theme = "catppuccin mocha"

font-feature = -liga
font-family = "SFMono Nerd Font"
font-size = 13
font-thicken = true

window-decoration = true
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true

macos-titlebar-style = tabs

# Inherit CWD when opening new tabs/splits/windows
window-inherit-working-directory = true
tab-inherit-working-directory = true
split-inherit-working-directory = true

# Close app when last window closes
quit-after-last-window-closed = true

# Cursor
cursor-style = bar
cursor-style-blink = false
cursor-click-to-move = true

# Shell integration (enables click-to-move, prompt awareness, etc.)
shell-integration = detect
shell-integration-features = no-cursor

# Clipboard & selection
# allow programs (e.g. Claude Code) to read clipboard via OSC 52 without prompting
clipboard-read = allow
copy-on-select = clipboard
selection-clear-on-copy = true
clipboard-trim-trailing-spaces = true
mouse-hide-while-typing = true

# Scrollback (16MB)
scrollback-limit = 16777216

# Splits
split-preserve-zoom = navigation

keybind = cmd+c=copy_to_clipboard
keybind = cmd+v=paste_from_clipboard

keybind = cmd+left=previous_tab
keybind = cmd+right=next_tab
keybind = cmd+t=new_tab
keybind = cmd+n=new_window
keybind = cmd+w=close_surface

keybind = cmd+e=equalize_splits
keybind = cmd+z=toggle_split_zoom
keybind = cmd+d=new_split:right
keybind = cmd+shift+d=new_split:down
